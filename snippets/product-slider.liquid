{%- if product != blank -%}
  {%- assign is_on_sale = false -%}
  {%- if product.compare_at_price_max > product.price_min -%}
    {%- assign is_on_sale = true -%}
  {%- endif -%}

  <product-slider class="product-slider" data-product-slider data-section-id="{{ section_id }}">
    <div class="product-slider__stage">
      {%- render 'product-badge', product: product, show_badge: true -%}

      <div
        class="product-slider__carousel"
        data-slick='{"mobileFirst": true, "arrows": false, "dots": true, "appendDots": "#ProductSliderDots-{{ section_id }}", "adaptiveHeight": false, "accessibility": true, "slidesToShow": 1, "slidesToScroll": 1, "responsive":[{"breakpoint": 576, "settings": {"slidesToShow": 2}}, {"breakpoint": 992, "settings": {"dots": false}}, {"breakpoint": 1200, "settings": {"slidesToShow": 1}}]}'
        aria-label="Product images"
      >
        {%- for image in product.images -%}
          <div class="product-slider__slide">
            <div class="product-slider__frame">
              {%- render
                'object-image',
                object_image: image,
                class: 'product-slider__image',
                fit: 'contain',
                sizes: '(min-width: 992px) 50vw, 100vw',
                loading: 'lazy'
              -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div id="ProductSliderDots-{{ section_id }}" class="product-slider__dots" aria-hidden="false"></div>

    {%- if product.images.size > 1 -%}
      <div class="product-slider__thumbs-wrap" aria-label="Product image thumbnails">
        {%- if product.images.size > 4 -%}
          <button
            id="ProductSliderThumbPrev-{{ section_id }}"
            class="product-slider__thumb-nav product-slider__thumb-nav--prev"
            type="button"
            aria-label="Previous thumbnails"
          >
            {%- render 'icon-button', direction: 'left' -%}
          </button>
        {%- endif -%}

        <div
          class="product-slider__thumbs"
          role="tablist"
          {% if product.images.size > 4 %}
            data-slick='{"arrows": true, "dots": false, "infinite": false, "slidesToShow": 4, "slidesToScroll": 1, "prevArrow":"#ProductSliderThumbPrev-{{ section_id }}", "nextArrow":"#ProductSliderThumbNext-{{ section_id }}", "accessibility": true}'
          {% endif %}
        >
          {%- for image in product.images -%}
            <button
              class="product-slider__thumb"
              type="button"
              data-product-slider-thumb
              data-slide-index="{{ forloop.index0 }}"
            >
              <span class="visually-hidden">View image {{ forloop.index }}</span>
              {%- render
                'object-image',
                object_image: image,
                class: 'product-slider__thumb-image',
                fit: 'cover',
                width: 100,
                height: 100,
                sizes: '100px',
                loading: 'lazy'
              -%}
            </button>
          {%- endfor -%}
        </div>

        {%- if product.images.size > 4 -%}
          <button
            id="ProductSliderThumbNext-{{ section_id }}"
            class="product-slider__thumb-nav product-slider__thumb-nav--next"
            type="button"
            aria-label="Next thumbnails"
          >
            {%- render 'icon-button', direction: 'right' -%}
          </button>
        {%- endif -%}
      </div>
    {%- endif -%}
  </product-slider>
{%- endif -%}

