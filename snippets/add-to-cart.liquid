{% if product.available %}
<form id="add-to-cart-form" class="add-to-cart-form">
    
    {% if product.variants_count > 1 %}
        <div class="variant-selector">
            <label for="variant-select" class="visually-hidden">Select Option:</label>
            <select id="variant-select" name="variant" required>
                {% for variant in product.variants %}
                    <option 
                        value="{{ variant.id }}" 
                        data-price="{{ variant.price }}" 
                        data-compare-price="{{ variant.compare_at_price | default: 0 }}"
                        {% if forloop.first %}selected{% endif %}
                    >
                        {{ variant.title }} - {{ variant.price | money }}
                    </option>
                {% endfor %}
            </select>
        </div>
    {% endif %}
    
    <div class="quantity-selector">
        <button type="button" class="quantity-btn decrement" id="decrement-btn">-</button>
        
        <input 
            type="number" 
            id="quantity-input" 
            name="quantity"
            value="1" 
            min="1" 
            max="99"
            readonly
        />
        
        <button type="button" class="quantity-btn increment" id="increment-btn">+</button>
    </div>
    
    <input type="hidden" id="variant-id-input" name="id" value="" />
    
    <button type="submit" class="button--atc" id="add-to-cart-btn">
        Add to Cart
    </button>
</form>

<!-- Pass Shopify data safely -->
<script>
window.productData = {
    defaultVariantId: {{ product.variants.first.id }},
    defaultPrice: {{ product.variants.first.price }},
    defaultComparePrice: {{ product.variants.first.compare_at_price | default: 0 }},
    currency: "{{ shop.currency }}"
};
</script>

{{ 'product-form.js' | asset_url | script_tag }}

{% else %}
<button class="button-atc" disabled>Out of Stock</button>
{% endif %}