{%- if product == blank -%}
  {%- render 'utility.make-section-placeholder', filename: 'product.liquid' -%}
{%- else -%}
  <div class="product" data-product-section data-section-id="{{ section.id }}">
    <div class="container-lg">
      <div class="row g-4 g-lg-6">
        <div class="col-12 col-lg-6">
          {%- render 'product-slider', product: product, section_id: section.id -%}
        </div>

        <div class="col-12 col-lg-6">
          <div class="product__main">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'title' -%}
                  <h1 class="product__title" {{ block.shopify_attributes }}>{{ product.title }}</h1>

                {%- when 'price' -%}
                  {%- render 'product-price', product: product, block: block, section_id: section.id -%}

                {%- when 'description' -%}
                  {%- if product.description != blank -%}
                    <p class="product__description" {{ block.shopify_attributes }}>
                      {{- product.description | strip_html -}}
                    </p>
                  {%- endif -%}

                {%- when 'product_form' -%}
                  {%- render 'product-form', product: product, block: block, section_id: section.id -%}

                {%- when 'accordion_zone' -%}
                  {%- render 'product-accordions', product: product, blocks: section.blocks, block: block, section_id: section.id -%}

                {%- when 'accordion_item' -%}
                  {%- continue -%}
              {%- endcase -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
{%- endif -%}

{%- schema -%}
{
  "name": "Product",
  "tag": "section",
  "settings": [],
  "blocks": [
    {
      "type": "title",
      "name": "Title",
      "limit": 1
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1
    },
    {
      "type": "product_form",
      "name": "Product form",
      "limit": 1
    },
    {
      "type": "accordion_zone",
      "name": "Accordion zone",
      "limit": 1
    },
    {
      "type": "accordion_item",
      "name": "Accordion item",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Product details"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "info": "Use “Connect dynamic source” to bind a product metafield (for example Accordion → Product details)."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product",
      "blocks": [
        {
          "type": "title"
        },
        {
          "type": "price"
        },
        {
          "type": "description"
        },
        {
          "type": "product_form"
        },
        {
          "type": "accordion_zone"
        },
        {
          "type": "accordion_item",
          "settings": {
            "heading": "Product details"
          }
        },
        {
          "type": "accordion_item",
          "settings": {
            "heading": "Ingredients"
          }
        },
        {
          "type": "accordion_item",
          "settings": {
            "heading": "How it's made"
          }
        },
        {
          "type": "accordion_item",
          "settings": {
            "heading": "Where it's made"
          }
        },
        {
          "type": "accordion_item",
          "settings": {
            "heading": "How to use"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{%- endschema -%}
